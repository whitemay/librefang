{
  "name": "librefang-web-new",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "predev": "tsx scripts/fetch-registry.ts && tsx scripts/gen-og-images.ts && tsx scripts/gen-rss.ts",
    "dev": "vite",
    "fetch-registry": "tsx scripts/fetch-registry.ts",
    "gen-og": "tsx scripts/gen-og-images.ts",
    "gen-rss": "tsx scripts/gen-rss.ts",
    "prebuild": "tsx scripts/fetch-registry.ts && tsx scripts/gen-og-images.ts && tsx scripts/gen-rss.ts",
    "build": "vite build",
    "lint": "tsc --noEmit",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.95.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
